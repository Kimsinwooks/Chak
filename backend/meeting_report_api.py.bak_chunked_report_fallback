    for route in router.routes:
        route_path = getattr(route, "path", "")
        route_methods = set(getattr(route, "methods", []) or [])

        if route_path == path and (not methods or route_methods & methods):
            print(f"[MEETING_REPORT_OVERRIDE] removed route {route_path} {route_methods}")
            continue

        kept.append(route)

    router.routes = kept


