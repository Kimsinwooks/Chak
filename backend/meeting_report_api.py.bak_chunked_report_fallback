def __normalize_week_label(value: str = "", idx: int = 1, text: str = "") -> str:
    raw = str(value or "").strip()
    source = f"{raw}\n{text or ''}".strip()

    if raw:
        m = re.search(r"(\d+)\s*주\s*차?", raw)
        if m:
            return f"{int(m.group(1))}주차"

        if re.fullmatch(r"\d+", raw):
            return f"{int(raw)}주차"

        if raw in {"이번 주", "이번주"}:
            return "1주차"

        if raw in {"다음 주", "다음주"}:
            return "2주차"

        if raw in {"다다음 주", "다다음주"}:
            return "3주차"

        if "최종" in raw:
            return "최종발표 주차"

        if "중간" in raw:
            return "중간발표 주차"

        return raw[:30]

    m = re.search(r"(\d+)\s*주\s*차?", source)
    if m:
        return f"{int(m.group(1))}주차"

    if re.search(r"이번\s*주", source):
        return "1주차"

    if re.search(r"다음\s*주", source):
        return "2주차"

    if re.search(r"다다음\s*주", source):
        return "3주차"

    if re.search(r"중간\s*발표|중간\s*점검", source):
        return "중간발표 주차"

    if re.search(r"최종\s*발표|최종\s*제출|마감", source):
        return "최종발표 주차"

    if idx <= 5:
        return f"{idx}주차"

    return ""


