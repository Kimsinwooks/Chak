def __route_path_matches(route_path: str, target: str) -> bool:
    rp = str(route_path or "")
    tg = str(target or "")

    if rp == tg:
        return True

    if rp == f"/meeting-report{tg}":
        return True

    if rp.endswith(tg):
        return True

    return False


def __remove_report_routes_v4(targets):
    """
    targets: list of (path, methods_set)
    path examples:
      /upload-audio
      /{session_id}/transcript
      /{session_id}/regenerate
      /{session_id}
    """
    kept = []

    for route in router.routes:
        route_path = getattr(route, "path", "")
        route_methods = set(getattr(route, "methods", []) or [])

        remove = False

        for target_path, target_methods in targets:
            target_methods = set(target_methods or [])

            if __route_path_matches(route_path, target_path):
                if not target_methods or route_methods & target_methods:
                    remove = True
                    break

        if remove:
            print(f"[MEETING_REPORT_OVERRIDE_4] removed route {route_methods} {route_path}")
            continue

        kept.append(route)

    router.routes = kept


