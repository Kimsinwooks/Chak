    file: UploadFile = File(...),
    stt_model: str = Form("medium"),
    language: str = Form("ko"),
    room_name: str = Form("default_room"),
    analyze_after: str = Form("0"),
    diarization_enabled: str = Form("1"),
    speaker_count: str = Form(""),
):
    ensure_report_tables()

    allowed = {
        ".wav",
        ".mp3",
        ".m4a",
        ".webm",
        ".mp4",
        ".aac",
        ".ogg",
        ".flac",
        ".wma",
        ".wmv",
    }

    ext = Path(file.filename).suffix.lower()

    if ext not in allowed:
        raise HTTPException(status_code=400, detail="음성/영상 파일만 업로드할 수 있습니다.")

    if stt_model not in ALLOWED_STT_MODELS:
        stt_model = "medium"

    room_name = room_name or "default_room"

    session_id = save_session(
        title=f"{Path(file.filename).stem} ({stt_model})",
        meeting_type="uploaded_audio",
        room_name=room_name,
    )

    upload_dir = DATA_DIR / "uploaded_audio" / session_id
    upload_dir.mkdir(parents=True, exist_ok=True)

    dst = upload_dir / file.filename

    with open(dst, "wb") as f:
        f.write(await file.read())

    diar_enabled = __truthy(diarization_enabled)
    spk_count = None

    try:
        if str(speaker_count).strip():
            spk_count = int(speaker_count)
    except Exception:
        spk_count = None

    try:
        transcript = transcribe_audio_with_selected_model(
            str(dst),
            model_name=stt_model,
            language=language or "ko",
            diarization_enabled=diar_enabled,
            speaker_count=spk_count,
        )
    except Exception as e:
        release_stt_models()
        raise HTTPException(status_code=500, detail=f"STT 변환 실패: {str(e)}")

    release_stt_models()

    save_library_item(
        session_id=session_id,
        bucket="post_meeting_recordings",
        kind=f"uploaded_audio_transcript_{stt_model}",
        name=file.filename,
        file_path=str(dst),
        text_content=transcript,
        room_name=room_name,
    )

    transcript_lines = extract_transcript_lines(transcript)
    save_transcript_lines_to_db(session_id, room_name, transcript_lines)

    speakers = []
    for line in transcript_lines:
        speaker = line.get("speaker") or "익명1"
        if speaker not in speakers:
            speakers.append(speaker)

    should_analyze = str(analyze_after).lower() in {"1", "true", "yes", "y"}

    report = None

    if should_analyze:
        session = read_session(session_id)
        ai_events = read_ai_events(session_id)

        release_stt_models()

        report = generate_slm_report(session, transcript, transcript_lines, ai_events)
        report["sttModel"] = stt_model
        report["language"] = language or "ko"
        report["diarizationStatus"] = "applied" if len(speakers) > 1 else "fallback_single_speaker"
        report["diarizationSpeakers"] = speakers

        output_info = save_report_outputs(session, report)
        report["outputInfo"] = output_info

        cache_report(session_id, report, output_info)

    status = "applied" if len(speakers) > 1 else "fallback_single_speaker"

    if diar_enabled and len(speakers) <= 1 and __DIARIZATION_LOAD_ERROR:
        note = f"화자 분리 fallback: {__DIARIZATION_LOAD_ERROR}"
    elif diar_enabled and len(speakers) <= 1:
        note = "화자 분리를 시도했지만 감지된 화자가 1명입니다."
    elif diar_enabled:
        note = f"화자 분리 적용됨: {', '.join(speakers)}"
    else:
        note = "화자 분리 옵션이 꺼져 있어 익명1 기준으로 저장했습니다."

    return {
        "sessionId": session_id,
        "filename": file.filename,
        "sttModel": stt_model,
        "language": language or "ko",
        "roomName": room_name,
        "transcriptPreview": transcript[:800],
        "report": report,
        "analysisDeferred": not should_analyze,
        "diarizationStatus": status,
        "diarizationSpeakers": speakers,
        "diarizationNote": note,
        "message": (
            "STT 변환 완료. 분석 화면에서 Gemma 회의 분석을 별도로 생성합니다."
            if not should_analyze
            else "STT 변환 및 Gemma 분석 완료."
        ),
    }


@router.get("/{session_id}/transcript")
def get_meeting_transcript(session_id: str):
    ensure_report_tables()

    conn = get_conn()
    rows = conn.execute(
        """
        SELECT *
        FROM transcript_lines
        WHERE session_id = ?
        ORDER BY start_sec ASC, end_sec ASC
        """,
        (session_id,),
    ).fetchall()
    conn.close()

    if rows:
        lines = []
        speakers = []
        sources = set()

        for r in rows:
            speaker = r["speaker"] or "익명1"
            if speaker not in speakers:
                speakers.append(speaker)

            sources.add(r["source"] or "")

            lines.append(
                {
                    "startSec": r["start_sec"],
                    "endSec": r["end_sec"],
                    "start": format_sec(r["start_sec"]),
                    "end": format_sec(r["end_sec"]),
                    "speaker": speaker,
                    "speakerId": r["speaker_id"],
                    "text": r["text"],
                }
            )

        diar_applied = len([s for s in speakers if s.startswith("익명")]) > 1
        status = "applied" if diar_applied else "fallback_single_speaker"

        return {
            "sessionId": session_id,
            "transcriptText": build_transcript_text(lines),
            "transcriptLines": lines,
            "speakers": speakers,
            "diarizationStatus": status,
            "diarizationNote": (
                f"화자 분리 적용됨: {', '.join(speakers)}"
                if diar_applied
                else "현재 저장된 STT는 단일 화자 또는 fallback 결과입니다."
            ),
        }

    text = read_transcript_text(session_id)
    lines = extract_transcript_lines(text)
    session = read_session(session_id)

    if session:
        room_name = get_room_name_from_session(session)
        save_transcript_lines_to_db(session_id, room_name, lines)

    speakers = []

    for line in lines:
        speaker = line.get("speaker") or "익명1"
        if speaker not in speakers:
            speakers.append(speaker)

    return {
        "sessionId": session_id,
        "transcriptText": text,
        "transcriptLines": lines,
        "speakers": speakers or ["익명1"],
        "diarizationStatus": "fallback_single_speaker",
        "diarizationNote": "저장된 transcript_lines가 없어 기존 STT 텍스트를 기준으로 복원했습니다.",
    }


