def report_output_dir(room_name: str, session_id: str) -> Path:
    return OUTPUT_ROOT / sanitize_path_part(room_name) / sanitize_path_part(session_id)


def write_text(path: Path, content: str):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content or "", encoding="utf-8")


def write_json(path: Path, data):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")


def build_todo_markdown(todo_items, calendar_suggestions):
    out = ["# To-Do List", ""]

    if not todo_items:
        out.append("- 생성된 To-Do가 없습니다.")
    else:
        for i, todo in enumerate(todo_items, start=1):
            out.append(f"## {i}. {todo.get('title')}")
            out.append("")
            out.append(f"- 설명: {todo.get('description') or '-'}")
            out.append(f"- 담당 유형: {todo.get('assigneeType') or 'team'}")
            out.append(f"- 담당자: {todo.get('assigneeName') or '-'}")
            out.append(f"- 우선순위: {todo.get('priority') or 'medium'}")
            out.append(f"- 상태: {todo.get('status') or 'open'}")
            out.append(f"- 추천 마감일: {todo.get('recommendedDueDate') or '-'}")
            out.append(f"- 주차: {todo.get('weekLabel') or '-'}")
            out.append(f"- 캘린더 범위: {todo.get('calendarScope') or 'team'}")
            out.append("")

    out.append("---")
    out.append("")
    out.append("# Calendar Suggestions")
    out.append("")

    if not calendar_suggestions:
        out.append("- 추천 일정이 없습니다.")
    else:
        for i, item in enumerate(calendar_suggestions, start=1):
            out.append(f"## {i}. {item.get('title')}")
            out.append("")
            out.append(f"- 설명: {item.get('description') or '-'}")
            out.append(f"- 범위: {item.get('scope') or 'team'}")
            out.append(f"- 추천 날짜: {item.get('recommendedDate') or '-'}")
            out.append(f"- 주차: {item.get('weekLabel') or '-'}")
            out.append(f"- 이유: {item.get('reason') or '-'}")
            out.append("")

    return "\n".join(out)


def build_transcript_text(transcript_lines):
    return "\n".join(
        [
            f"[{line['start']}~{line['end']}] {line['speaker']}: {line['text']}"
            for line in transcript_lines
        ]
    )


