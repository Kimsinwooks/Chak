def __seconds_to_label(sec: float) -> str:
    try:
        sec = int(float(sec))
    except Exception:
        sec = 0

    m = sec // 60
    s = sec % 60
    return f"{m:02d}:{s:02d}"


def __parse_time_to_sec(value):
    text = str(value or "").strip()

    m = re.match(r"(?:(\d+):)?(\d+):(\d+)", text)
    if not m:
        return 0.0

    if m.group(1) is not None:
        h = int(m.group(1))
        mm = int(m.group(2))
        ss = int(m.group(3))
        return float(h * 3600 + mm * 60 + ss)

    mm = int(m.group(2))
    ss = int(m.group(3))
    return float(mm * 60 + ss)


def __line_to_segment(line: str):
    raw = str(line or "").strip()
    if not raw:
        return None

    # [00:00~00:06] 익명1: text
    m = re.match(
        r"^\[(?P<start>[0-9:]+)\s*~\s*(?P<end>[0-9:]+)\]\s*(?P<speaker>[^:：]+)[:：]\s*(?P<text>.*)$",
        raw,
    )

    if m:
        start = __parse_time_to_sec(m.group("start"))
        end = __parse_time_to_sec(m.group("end"))

        if end <= start:
            end = start + 1

        return {
            "startSec": start,
            "endSec": end,
            "speaker": m.group("speaker").strip() or "익명1",
            "text": m.group("text").strip(),
            "raw": raw,
        }

    return {
        "startSec": 0.0,
        "endSec": 1.0,
        "speaker": "익명1",
        "text": raw,
        "raw": raw,
    }


def __extract_segments_from_report_inputs(transcript_text, transcript_lines):
    segments = []

    if transcript_lines:
        for item in transcript_lines:
            if isinstance(item, dict):
                text = str(item.get("text") or "").strip()
                if not text:
                    continue

                start = float(item.get("startSec") or item.get("start_sec") or 0)
                end = float(item.get("endSec") or item.get("end_sec") or start + 1)

                if end <= start:
                    end = start + 1

                segments.append(
                    {
                        "startSec": start,
                        "endSec": end,
                        "speaker": item.get("speaker") or "익명1",
                        "text": text,
                        "raw": f"[{__seconds_to_label(start)}~{__seconds_to_label(end)}] {item.get('speaker') or '익명1'}: {text}",
                    }
                )

    if not segments:
        for line in str(transcript_text or "").splitlines():
            seg = __line_to_segment(line)
            if seg and seg["text"]:
                segments.append(seg)

    segments.sort(key=lambda x: (x["startSec"], x["endSec"]))

    # 시간이 전부 0이면 순서 기반으로 6초 간격 부여
    if segments and max([s["endSec"] for s in segments]) <= 1.0:
        for idx, seg in enumerate(segments):
            seg["startSec"] = float(idx * 6)
            seg["endSec"] = float(idx * 6 + 5)

    return segments


def __chunk_segments(segments, target_chunk_sec=420, min_chunks=3):
    if not segments:
        return []

    total_start = min(s["startSec"] for s in segments)
    total_end = max(s["endSec"] for s in segments)

    if total_end <= total_start:
        total_end = total_start + len(segments) * 6

    total_sec = max(1, total_end - total_start)

    if total_sec < target_chunk_sec * min_chunks:
        chunk_count = min(max(min_chunks, 1), max(1, len(segments)))
        chunk_size = max(1, math.ceil(len(segments) / chunk_count))

        chunks = []
        for i in range(0, len(segments), chunk_size):
            part = segments[i : i + chunk_size]
            if part:
                chunks.append(part)

        return chunks

    chunks = []
    current = []
    chunk_start = segments[0]["startSec"]

    for seg in segments:
        if current and seg["startSec"] - chunk_start >= target_chunk_sec:
            chunks.append(current)
            current = []
            chunk_start = seg["startSec"]

        current.append(seg)

    if current:
        chunks.append(current)

    return chunks


def __keywords_from_text(text: str, top_k=5):
    text = str(text or "")

    words = re.findall(r"[가-힣A-Za-z0-9]{2,}", text)

    stop = {
        "익명1", "익명2", "익명3", "익명4",
        "그리고", "근데", "그러면", "지금", "이거", "저거", "그거",
        "아니", "네", "예", "좋아요", "해주세요", "합니다", "있습니다",
        "회의", "내용", "관련", "부분", "진행", "확인",
    }

    filtered = [w for w in words if w not in stop and len(w) >= 2]

    if not filtered:
        return []

    counter = __Counter(filtered)

    return [w for w, _ in counter.most_common(top_k)]


def __guess_topic_title(chunk_text: str, idx: int):
    text = str(chunk_text or "")

    rules = [
        (r"목요일|다음\s*달|언제|날짜|일정|미팅|회의", "일정 및 회의 시점 논의"),
        (r"부탁|알려줘|공유|전달|준비", "역할 분담 및 준비 요청"),
        (r"자료|파일|업로드|문서|정리", "자료 준비 및 공유"),
        (r"발표|중간|최종|보고|제출", "발표 및 제출 준비"),
        (r"문제|안\s*됨|오류|어려움|막힘", "문제 상황 및 해결 논의"),
        (r"캘린더|To-Do|할\s*일|태스크|작업", "후속 작업 및 일정 관리"),
    ]

    for pattern, title in rules:
        if re.search(pattern, text):
            return title

    kws = __keywords_from_text(text, top_k=2)

    if kws:
        return f"{' / '.join(kws)} 관련 논의"

    return f"{idx}번째 논의 구간"


def __summarize_chunk_heuristic(chunk):
    texts = [s["text"] for s in chunk if s.get("text")]
    joined = " ".join(texts)

    if not texts:
        return "해당 구간에서 유의미한 발화가 충분히 확인되지 않았습니다."

    # 너무 원문처럼 길게 넣지 않기 위해 핵심 문장 3개까지만
    useful = []
    for t in texts:
        t = str(t or "").strip()
        if not t:
            continue
        if len(t) < 3:
            continue
        if t in useful:
            continue
        useful.append(t)
        if len(useful) >= 3:
            break

    title_hint = __guess_topic_title(joined, 1)

    if "일정" in title_hint or "회의 시점" in title_hint:
        base = "회의 일정과 진행 시점을 확인하는 발화가 중심이었습니다."
    elif "역할" in title_hint or "준비" in title_hint:
        base = "참여자 간 준비 요청과 역할 분담에 관한 발화가 중심이었습니다."
    elif "자료" in title_hint:
        base = "회의에 필요한 자료 준비와 공유 방식이 논의되었습니다."
    elif "문제" in title_hint:
        base = "진행 중 발생한 문제 상황과 해결 필요 사항이 언급되었습니다."
    else:
        base = "해당 구간에서는 회의 진행을 위한 주요 논의가 이어졌습니다."

    if useful:
        return base + " 핵심 발화는 " + " / ".join(useful[:3]) + " 등입니다."

    return base


def __make_chunk_topic(chunk, idx, total_sec):
    start = float(chunk[0]["startSec"])
    end = float(chunk[-1]["endSec"])

    if end <= start:
        end = start + 1

    joined = " ".join([s["text"] for s in chunk if s.get("text")])
    title = __guess_topic_title(joined, idx)
    summary = __summarize_chunk_heuristic(chunk)
    keywords = __keywords_from_text(joined, top_k=6)

    detail_lines = []
    for s in chunk[:12]:
        detail_lines.append(
            f"[{__seconds_to_label(s['startSec'])}~{__seconds_to_label(s['endSec'])}] {s.get('speaker') or '익명1'}: {s.get('text') or ''}"
        )

    if len(chunk) > 12:
        detail_lines.append(f"... 이하 {len(chunk) - 12}개 발화 생략")

    width = max(3, round(((end - start) / max(total_sec, 1)) * 100, 2))

    return {
        "id": f"topic_{idx}",
        "title": title,
        "summary": summary,
        "detail": "\n".join(detail_lines),
        "startSec": start,
        "endSec": end,
        "start": __seconds_to_label(start),
        "end": __seconds_to_label(end),
        "timeRange": f"{__seconds_to_label(start)}~{__seconds_to_label(end)}",
        "durationSec": max(1, int(end - start)),
        "percentage": width,
        "keywords": keywords,
        "speakerSummary": {},
    }


