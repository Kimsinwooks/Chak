    conn = get_conn()
    cur = conn.cursor()

    cur.execute(
        """
        DELETE FROM transcript_lines
        WHERE session_id = ?
        """,
        (session_id,),
    )

    now = now_iso()

    for line in transcript_lines:
        text = (line.get("text") or "").strip()
        if not text:
            continue

        speaker = line.get("speaker") or "익명1"
        speaker_id = line.get("speakerId") or line.get("speaker_id") or speaker
        source = "pyannote_whisper" if speaker != "익명1" else "whisper"

        cur.execute(
            """
            INSERT INTO transcript_lines (
                id,
                room_name,
                session_id,
                start_sec,
                end_sec,
                speaker,
                speaker_id,
                text,
                source,
                created_at
            )
            VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
            """,
            (
                str(uuid.uuid4()),
                room_name,
                session_id,
                float(line.get("startSec", 0)),
                float(line.get("endSec", 0)),
                speaker,
                speaker_id,
                text,
                source,
                now,
            ),
        )

    conn.commit()
    conn.close()


def __remove_meeting_report_router_route(path: str, methods=None):
