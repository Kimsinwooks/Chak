      "title": "해야 할 일 제목",
      "description": "상세 설명",
      "assigneeType": "team",
      "assigneeName": "",
      "priority": "medium",
      "status": "open",
      "recommendedDueDate": "",
      "dueDate": "",
      "weekLabel": "1주차",
      "calendarScope": "team",
      "sourceTopicId": "topic_1"
    }}
  ],
  "calendarSuggestions": [
    {{
      "id": "calendar_suggestion_1",
      "title": "캘린더에 추가할 일정 제목",
      "description": "일정 설명",
      "scope": "team",
      "recommendedDate": "",
