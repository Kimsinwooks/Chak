def __canonical_time_text(sec):
    try:
        return format_sec(float(sec))
    except Exception:
        return "00:00"


def __canonical_block_from_any(item, idx):
    if not isinstance(item, dict):
        item = {}

    start_sec = item.get("startSec")
    if start_sec is None:
        start_sec = item.get("start_sec")
    if start_sec is None:
        start_sec = 0

    end_sec = item.get("endSec")
    if end_sec is None:
        end_sec = item.get("end_sec")
    if end_sec is None:
        end_sec = start_sec + 1

    try:
        start_sec = float(start_sec)
    except Exception:
        start_sec = 0.0

    try:
        end_sec = float(end_sec)
    except Exception:
        end_sec = start_sec + 1

    if end_sec <= start_sec:
        end_sec = start_sec + 1

    title = (
        item.get("topic")
        or item.get("title")
        or item.get("name")
        or f"{idx}번째 논의 구간"
    )

    summary = (
        item.get("summary")
        or item.get("description")
        or item.get("overview")
        or ""
    )

    text = (
        item.get("text")
        or item.get("detail")
        or item.get("details")
        or summary
        or ""
    )

    start = item.get("start") or __canonical_time_text(start_sec)
    end = item.get("end") or __canonical_time_text(end_sec)

    return {
        "id": str(item.get("id") or f"topic_{idx}"),
        "topic": str(title).strip() or f"{idx}번째 논의 구간",
        "title": str(title).strip() or f"{idx}번째 논의 구간",
        "startSec": start_sec,
        "endSec": end_sec,
        "start": start,
        "end": end,
        "durationSec": max(1, int(end_sec - start_sec)),
        "keywords": item.get("keywords") or [],
        "summary": str(summary).strip(),
        "text": str(text).strip(),
        "detail": str(text).strip(),
        "lineIndexes": item.get("lineIndexes") or item.get("line_indexes") or [],
    }


def __canonicalize_report_for_frontend(report, session=None, transcript_lines=None, ai_events=None):
    if not isinstance(report, dict):
        report = {}

    transcript_lines = transcript_lines or report.get("transcriptLines") or []
    ai_events = ai_events or report.get("aiEvents") or []

    session_obj = report.get("session") or __safe_get_session_dict(session)

    # 1) source blocks 결정
    source_blocks = None

    if isinstance(report.get("topicBlocks"), list) and report.get("topicBlocks"):
        source_blocks = report.get("topicBlocks")
    elif isinstance(report.get("topics"), list) and report.get("topics"):
        source_blocks = report.get("topics")
    elif isinstance(report.get("progressBars"), list) and report.get("progressBars"):
        source_blocks = report.get("progressBars")
    else:
        source_blocks = []

    topic_blocks = [
        __canonical_block_from_any(block, idx)
        for idx, block in enumerate(source_blocks, start=1)
    ]

    # 2) 그래도 topicBlocks가 없거나 1개짜리 원문 덩어리면 structured fallback 재생성
    joined_for_check = "\n".join(
        [
            str(b.get("summary") or "") + "\n" + str(b.get("text") or "")
            for b in topic_blocks
        ]
    )

    timestamp_count = len(re.findall(r"\[[0-9:]+~[0-9:]+\]", joined_for_check))

    if len(topic_blocks) <= 1 or timestamp_count >= 12:
        try:
            fallback = __build_structured_fallback_report(
                session=session,
                transcript_text=build_transcript_text(transcript_lines) if transcript_lines else "",
                transcript_lines=transcript_lines,
                ai_events=ai_events,
                reason="override4_frontend_canonical_bad_blocks",
            )

            source_blocks = fallback.get("topicBlocks") or fallback.get("topics") or fallback.get("progressBars") or []
            topic_blocks = [
                __canonical_block_from_any(block, idx)
                for idx, block in enumerate(source_blocks, start=1)
            ]

            report["fallbackReason"] = fallback.get("fallbackReason")
            report["warnings"] = fallback.get("warnings") or report.get("warnings") or []
            report["summary"] = fallback.get("summary") or report.get("summary")
            report["overallSummary"] = fallback.get("overallSummary") or report.get("overallSummary")

            if not report.get("todoItems"):
                report["todoItems"] = fallback.get("todoItems") or fallback.get("todos") or []

            if not report.get("calendarSuggestions"):
                report["calendarSuggestions"] = fallback.get("calendarSuggestions") or []

        except Exception as e:
            print(f"[MEETING_REPORT_OVERRIDE_4] structured fallback failed: {e}")

    # 3) totalSec 보정
    total_sec = report.get("totalSec") or report.get("totalDurationSec") or 0

    try:
        total_sec = float(total_sec)
    except Exception:
        total_sec = 0

    if topic_blocks:
        total_sec = max(total_sec, max(float(b.get("endSec") or 0) for b in topic_blocks))

    if transcript_lines:
        try:
            total_sec = max(total_sec, max(float(x.get("endSec") or 0) for x in transcript_lines))
        except Exception:
            pass

    if total_sec <= 0:
        total_sec = 1

    # 4) todo/calendar 보정
    todo_items = report.get("todoItems") or report.get("todos") or []
    fixed_todos = []

    for idx, todo in enumerate(todo_items, start=1):
        fixed_todos.append(normalize_todo_item(todo, idx))

    if not fixed_todos and topic_blocks:
        try:
            fixed_todos = __make_todos_from_topics(topic_blocks)
        except Exception:
            fixed_todos = []

    calendar_suggestions = report.get("calendarSuggestions") or []

    if not calendar_suggestions:
        try:
            calendar_suggestions = build_fallback_calendar_suggestions(fixed_todos)
        except Exception:
            calendar_suggestions = []

    # 5) minutes/mindmap 보정
    if not report.get("minutesMarkdown"):
        try:
            report["minutesMarkdown"] = build_fallback_minutes(topic_blocks, ai_events)
        except Exception:
            report["minutesMarkdown"] = "# 회의록 정리\n\n- 회의 분석 결과를 생성했습니다."

    if not report.get("mindmapText"):
        try:
            report["mindmapText"] = build_mindmap_text(topic_blocks)
        except Exception:
            report["mindmapText"] = " -> ".join([b.get("topic") or "" for b in topic_blocks])

    report["session"] = session_obj
    report["totalSec"] = int(total_sec)
    report["transcriptLines"] = transcript_lines
    report["topicBlocks"] = topic_blocks
    report["topics"] = topic_blocks
    report["progressBars"] = topic_blocks
    report["todoItems"] = fixed_todos
    report["todos"] = fixed_todos
    report["calendarSuggestions"] = calendar_suggestions
    report["aiEvents"] = ai_events
    report["analysisMode"] = report.get("analysisMode") or "GEMMA_REPORT_TODO_OUTPUT"

    return report


def __report_bad_for_frontend(report):
    if not isinstance(report, dict):
        return True

    blocks = report.get("topicBlocks") or report.get("topics") or report.get("progressBars") or []

    if not isinstance(blocks, list) or len(blocks) <= 1:
        return True

    joined = "\n".join(
        [
            str(b.get("summary") or "") + "\n" + str(b.get("text") or "") + "\n" + str(b.get("detail") or "")
            for b in blocks
            if isinstance(b, dict)
        ]
    )

    if len(re.findall(r"\[[0-9:]+~[0-9:]+\]", joined)) >= 12:
        return True

    return False


