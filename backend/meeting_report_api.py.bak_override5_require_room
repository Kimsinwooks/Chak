def __looks_like_bad_report(report):
    if not isinstance(report, dict):
        return True

    topics = report.get("topics") or report.get("progressBars") or []

    if not isinstance(topics, list) or len(topics) <= 1:
        return True

    # topic summary/detail 안에 타임스탬프 원문이 과도하게 많으면 실패로 간주
    joined = "\n".join(
        [
            str(t.get("summary") or "") + "\n" + str(t.get("detail") or "")
            for t in topics
            if isinstance(t, dict)
        ]
    )

    timestamp_count = len(re.findall(r"\[[0-9:]+~[0-9:]+\]", joined))

    if timestamp_count >= 12:
        return True

    todo_items = report.get("todoItems") or report.get("todos") or []

    if not isinstance(todo_items, list) or len(todo_items) == 0:
        return True

    return False


def __build_structured_fallback_report(session, transcript_text, transcript_lines, ai_events=None, reason="fallback"):
    segments = __extract_segments_from_report_inputs(transcript_text, transcript_lines)

    if not segments:
        segments = [
            {
                "startSec": 0.0,
                "endSec": 60.0,
                "speaker": "익명1",
                "text": "분석 가능한 STT 발화가 충분하지 않습니다.",
                "raw": "분석 가능한 STT 발화가 충분하지 않습니다.",
            }
        ]

    total_start = min(s["startSec"] for s in segments)
    total_end = max(s["endSec"] for s in segments)

    if total_end <= total_start:
        total_end = total_start + 60

    total_sec = max(60, total_end - total_start)

    chunks = __chunk_segments(segments, target_chunk_sec=420, min_chunks=3)

    topics = []
    for idx, chunk in enumerate(chunks, start=1):
        if chunk:
            topics.append(__make_chunk_topic(chunk, idx, total_sec))

    if len(topics) == 1 and len(segments) >= 6:
        # 그래도 하나면 강제 3분할
        forced_chunks = __chunk_segments(segments, target_chunk_sec=999999, min_chunks=3)
        topics = [
            __make_chunk_topic(chunk, idx, total_sec)
            for idx, chunk in enumerate(forced_chunks, start=1)
            if chunk
        ]

    if not topics:
        topics = [
            {
                "id": "topic_1",
                "title": "회의 내용 확인 필요",
                "summary": "분석 가능한 회의 발화가 부족하여 상세 요약을 생성하지 못했습니다.",
                "detail": "",
                "startSec": 0,
                "endSec": total_sec,
                "start": "00:00",
                "end": __seconds_to_label(total_sec),
                "timeRange": f"00:00~{__seconds_to_label(total_sec)}",
                "durationSec": int(total_sec),
                "percentage": 100,
                "keywords": [],
                "speakerSummary": {},
            }
        ]

    todo_items = __make_todos_from_topics(topics)

    speaker_counter = __Counter()
    for s in segments:
        speaker_counter[s.get("speaker") or "익명1"] += 1

    speaker_summary = [
        {
            "speaker": speaker,
            "utteranceCount": count,
            "summary": f"{speaker}은/는 회의에서 {count}개의 발화를 기록했습니다.",
        }
        for speaker, count in speaker_counter.most_common()
    ]

    meeting_title = "회의 분석"
    try:
        if isinstance(session, dict):
            meeting_title = session.get("title") or meeting_title
        else:
            meeting_title = getattr(session, "title", meeting_title)
    except Exception:
        pass

    return {
        "mode": "SLM_FULL_TRANSCRIPT_ANALYSIS",
        "analysisMode": "chunked_structured_fallback",
        "fallbackReason": reason,
        "meetingTitle": meeting_title,
        "totalLength": f"{int(total_sec // 60)}:{int(total_sec % 60):02d}",
        "totalDurationSec": int(total_sec),
        "summary": "회의 STT를 시간 구간별로 나누어 주요 논의와 후속 작업을 구조화했습니다.",
        "overallSummary": "회의 STT를 기반으로 일정, 준비 사항, 후속 작업 중심의 논의 흐름을 정리했습니다.",
        "topics": topics,
        "progressBars": topics,
        "todoItems": todo_items,
        "todos": todo_items,
        "calendarSuggestions": [
            {
                "id": f"calendar_{idx}",
                "title": todo["title"],
                "description": todo["description"],
                "scope": "team",
                "recommendedDate": "",
                "weekLabel": todo["weekLabel"],
                "sourceTodoId": todo["id"],
                "reason": "회의 후속 작업 기반 추천 일정",
            }
            for idx, todo in enumerate(todo_items, start=1)
        ],
        "speakerSummary": speaker_summary,
        "aiEvents": ai_events or [],
        "warnings": [
            "Gemma 구조화 결과가 불완전하여 chunk 기반 fallback 분석을 사용했습니다.",
            "원문 전체를 그대로 표시하지 않고 시간 구간별 요약으로 변환했습니다.",
        ],
    }


